# Environment Configuration for Ceylon Sentinel AI

# ==========================================
# Backend Variables
# ==========================================
ENVIRONMENT=development
API_V1_STR=/api/v1
SECRET_KEY=generate_a_secure_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# ==========================================
# Frontend Variables
# ==========================================
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ==========================================
# Database Variables (PostgreSQL)
# ==========================================
POSTGRES_SERVER=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ceylon_sentinel
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/ceylon_sentinel

# ==========================================
# Redis Variables
# ==========================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ==========================================
# Qdrant Variables
# ==========================================
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_URL=http://qdrant:6333

# ==========================================
# Agent / External APIs
# ==========================================
OPENAI_API_KEY=your_openai_api_key_here
WEATHER_API_KEY=your_weather_api_key_here
NEWS_API_KEY=your_news_api_key_here

# ==========================================
# Data Ingestion Framework (Collectors)
# ==========================================

# News Sources
HIRU_NEWS_API_URL=https://api.example.com/hiru
ADA_DERANA_RSS_URL=http://adaderana.lk/rss.php
NEWSFIRST_RSS_URL=https://www.newsfirst.lk/rss/

# Weather Sources
OPENWEATHER_API_URL=https://api.openweathermap.org/data/2.5/weather
OPEN_METEO_API_URL=https://api.open-meteo.com/v1/forecast

# Finance Sources
EXCHANGE_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD
CBSL_API_URL=https://www.cbsl.gov.lk/api/exchangerates

# Collector Settings
COLLECTOR_TIMEOUT_SECONDS=10
COLLECTOR_RETRY_COUNT=3
COLLECTOR_POLLING_INTERVAL_SECONDS=300
